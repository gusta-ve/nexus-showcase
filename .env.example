# ───────────── Nexus — variáveis de ambiente ─────────────
# Copie para .env e preencha. O .env nunca é versionado (está no .gitignore).

# ──── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=nexus_db
POSTGRES_USER=nexus_user
# Senha do banco — gere uma forte:  openssl rand -base64 24
POSTGRES_PASSWORD=
# No deploy via docker-compose a connection string é montada a partir das vars
# acima. Pra rodar fora do compose, defina também:
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=nexus_db;Username=nexus_user;Password=<a senha acima>

# ──── Cofre de senhas (AES-256-GCM) ─────────────────────────
# Chave de criptografia do vault — gere com:  openssl rand -base64 32
# ⚠️  Trocar esta chave invalida todos os segredos já cifrados.
Security__EncryptionKey=

# ──── Identidade (admin root) ───────────────────────────────
# A senha é aplicada/reforçada no startup — não há default no código.
Identity__AdminEmail=admin@seudominio.com
# Senha do admin — gere uma forte:  openssl rand -base64 18
Identity__AdminPassword=

# ──── Domínio / TLS ─────────────────────────────────────────
# Hostname público para HTTPS automático (Caddy + Let's Encrypt).
NEXUS_DOMAIN=seudominio.com

# ──── Ambiente ──────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ════════════════════════════════════════════════════════════
#  OPCIONAIS — serviços env-gated (vazios = no-op, app sobe normal)
# ════════════════════════════════════════════════════════════

# ──── Email transacional (alerts pro admin) ─────────────────
# Dispara em: servidor caiu (ServerDown) e chamado novo (ClientWaiting).
# Recomendado: Resend (3000 emails/mês free, https://resend.com).
# Alternativas: Gmail SMTP (App Password), Postmark, SendGrid SMTP.
#
# ⚠️  Porta 587 (STARTTLS), NÃO 465 (SSL implícito): o SmtpClient do .NET
#     só faz STARTTLS via EnableSsl=true; 465 trava no handshake. Sempre 587.
#
# Resend:  Email__SmtpHost=smtp.resend.com  Email__SmtpUser=resend  Email__SmtpPass=re_xxxxx
# Gmail:   Email__SmtpHost=smtp.gmail.com   Email__SmtpUser=voce@gmail.com  Email__SmtpPass=<app password 16 dígitos>
Email__Enabled=false
Email__From="Nexus <noreply@seudominio.com>"
Email__AdminTo=voce@exemplo.com
Email__SmtpHost=
Email__SmtpPort=587
Email__SmtpUser=
Email__SmtpPass=
Email__UseSsl=true

# ──── Instância de demonstração (demo.gustavoti.com) ────────
# Só necessário se você subir o stack de demo (serviços *-demo do compose).
# Dados 100% fictícios e isolados; mesmo assim, nada de segredo no código.
DEMO_DB_PASSWORD=          # openssl rand -base64 24
DEMO_ENCRYPTION_KEY=       # openssl rand -base64 32
DEMO_ADMIN_PASSWORD=       # senha do admin de demo (aparece na tela de login)
