@using Nexus.Application.Features.Vault
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@implements IDisposable

<MudDialog>
    <DialogContent>
        <div class="vault-reveal">
            <div class="vault-reveal-row">
                <span class="vault-reveal-label">Nome</span>
                <span class="vault-reveal-val">@Secret.Name</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Secret.Username))
            {
                <div class="vault-reveal-row">
                    <span class="vault-reveal-label">Usuário</span>
                    <span class="vault-reveal-val">@Secret.Username</span>
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                   OnClick="@(() => Copy(Secret.Username!, "Usuário"))" />
                </div>
            }

            <div class="vault-reveal-row">
                <span class="vault-reveal-label">Senha</span>
                <code class="vault-reveal-secret">@(_showPassword ? Secret.Password : new string('•', Math.Min(Secret.Password.Length, 20)))</code>
                <MudIconButton Icon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                               Size="Size.Small" OnClick="@(() => _showPassword = !_showPassword)" />
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                               OnClick="@(() => Copy(Secret.Password, "Senha"))" />
            </div>

            @if (!string.IsNullOrWhiteSpace(Secret.Url))
            {
                <div class="vault-reveal-row">
                    <span class="vault-reveal-label">URL</span>
                    <a href="@Secret.Url" target="_blank" rel="noopener" class="vault-reveal-val">@Secret.Url</a>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Secret.Notes))
            {
                <div class="vault-reveal-notes">
                    <div class="vault-reveal-label">Notas</div>
                    <div>@Secret.Notes</div>
                </div>
            }

            <div class="vault-reveal-countdown">
                Esta janela fecha automaticamente em @_remaining s.
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))" Color="Color.Primary">Fechar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public RevealedSecretDto Secret { get; set; } = null!;

    private bool _showPassword = true;
    private int _remaining = 60;
    private Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new Timer(_ =>
        {
            _remaining--;
            InvokeAsync(StateHasChanged);
            if (_remaining <= 0)
            {
                _timer?.Dispose();
                InvokeAsync(() => MudDialog.Close(DialogResult.Ok(true)));
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task Copy(string text, string label)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            Snackbar.Add($"{label} copiado.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Não foi possível copiar (clipboard bloqueado).", Severity.Warning);
        }
    }

    public void Dispose() => _timer?.Dispose();
}
