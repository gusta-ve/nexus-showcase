@page "/portal/trocar-senha"
@layout ClientPortalLayout
@attribute [Authorize(Roles = "Client")]
@rendermode InteractiveServer
@using Nexus.Application.Common.Interfaces
@using Nexus.Application.Features.Portal
@inject IPortalAccessService Access
@inject AuthenticationStateProvider AuthState
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Trocar senha · Portal</PageTitle>

<div class="nexus-page-header">
    <div>
        <h1 class="nexus-h1">Trocar senha</h1>
        <p class="nexus-sub">Defina uma senha pessoal para seu acesso ao portal</p>
    </div>
</div>

<MudPaper Class="nexus-panel" Style="max-width:560px" Elevation="0">
    <MudForm @ref="_form" Model="_model">
        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.CurrentPassword" Label="Senha atual (temporária) *"
                              Required="true" InputType="InputType.Password" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.NewPassword" Label="Nova senha *"
                              Required="true" InputType="InputType.Password" Variant="Variant.Outlined"
                              HelperText="Mínimo 8 caracteres, com letras e números" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.ConfirmPassword" Label="Confirmar nova senha *"
                              Required="true" InputType="InputType.Password" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <div style="display:flex;justify-content:flex-end;margin-top:24px">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_saving">
                @(_saving ? "Salvando..." : "Trocar senha")
            </MudButton>
        </div>
    </MudForm>
</MudPaper>

@code {
    private MudForm _form = null!;
    private ChangePasswordDto _model = new();
    private bool _saving;
    private string? _userId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid || _userId is null) return;
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            Snackbar.Add("As senhas não conferem.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            var r = await Access.ChangePasswordAsync(_userId, _model.CurrentPassword, _model.NewPassword);
            if (!r.Succeeded) { Snackbar.Add(r.Error!, Severity.Error); return; }
            Snackbar.Add("Senha trocada com sucesso!", Severity.Success);
            Nav.NavigateTo("/portal", forceLoad: true);
        }
        finally { _saving = false; }
    }
}
