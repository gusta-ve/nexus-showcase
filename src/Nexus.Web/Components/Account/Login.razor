@page "/login"
@layout EmptyLayout
@using Microsoft.AspNetCore.Antiforgery
@attribute [AllowAnonymous]
@implements IDisposable
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpAccessor
@inject PersistentComponentState State
@inject NavigationManager Nav
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@rendermode InteractiveServer

<PageTitle>Entrar · Gustavo Almeida</PageTitle>

<div class="auth4">
    <a href="/?landing=1" class="auth4-back" aria-label="Voltar pro site">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M9 3l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        gustavoti.com
    </a>

    <div class="auth4-card">

        <!-- Left brand panel (hidden on mobile) -->
        <div class="auth4-panel">
            <a href="/" class="auth4-panel-brand" aria-label="Voltar para a página inicial">
                <HexLogomark Letter="G" Size="44" />
            </a>
            <h2 class="auth4-panel-title">Suporte de TI que funciona de verdade</h2>
            <p class="auth4-panel-desc">Acesse chamados, servidores, relatórios e muito mais em um só lugar.</p>
            <ul class="auth4-features">
                <li>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Abertura e acompanhamento de chamados
                </li>
                <li>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Monitoramento de servidores 24/7
                </li>
                <li>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Histórico, notas e relatórios completos
                </li>
                <li>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Notificações em tempo real
                </li>
            </ul>
        </div>

        <!-- Right form side -->
        <div class="auth4-form-side">
            <span class="auth4-eyebrow">Acesso restrito</span>
            <h1 class="auth4-title">Entrar na conta</h1>
            <p class="auth4-sub">Use o email e a senha que você recebeu.</p>

            @if (IsDemo)
            {
                <div style="margin:0 0 18px;padding:14px 16px;border:1px solid #1f2a33;border-radius:12px;background:#0d1115;">
                    <div style="font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:#00c2ff;font-weight:600;margin-bottom:8px;">
                        Ambiente de demonstração
                    </div>
                    <div style="font-size:13px;color:#93a1ad;line-height:1.8;">
                        Explore à vontade — dados fictícios, resetados periodicamente.<br />
                        <b style="color:#fff;">Admin (vê tudo)</b> — <code>demo@gustavoti.com</code> · <code>Demo@Nexus2026</code><br />
                        <b style="color:#fff;">Portal do cliente</b> — <code>portal@horizontecontabil.com.br</code> · <code>Portal@Demo2026</code>
                    </div>
                </div>
            }

            @if (HasError)
            {
                <div class="auth4-error">
                    <b>Não consegui entrar.</b>
                    <span>Confere o email e a senha. Esqueceu?
                        <a href="https://wa.me/5511942653054?text=Esqueci%20minha%20senha" target="_blank" rel="noopener">Me chama no WhatsApp.</a>
                    </span>
                </div>
            }

            @if (!string.IsNullOrEmpty(_tokenField) && !string.IsNullOrEmpty(_tokenValue))
            {
                <form method="post" action="/auth/login" class="auth4-form">
                    <input type="hidden" name="@_tokenField" value="@_tokenValue" />

                    <div class="auth4-field">
                        <label for="login-email">Email</label>
                        <input id="login-email" class="auth4-input" type="email" name="email"
                               placeholder="voce@exemplo.com" required autofocus autocomplete="username" />
                    </div>

                    <div class="auth4-field">
                        <div class="auth4-field-row">
                            <label for="login-password">Senha</label>
                            <a class="auth4-field-help"
                               href="https://wa.me/5511942653054?text=Esqueci%20minha%20senha"
                               target="_blank" rel="noopener">Esqueci</a>
                        </div>
                        <div class="auth4-pwd">
                            <input id="login-password" class="auth4-input"
                                   type="password"
                                   name="password" placeholder="••••••••" required autocomplete="current-password" />
                            <button type="button" class="auth4-pwd-toggle" aria-label="Mostrar/esconder senha">
                                <svg class="auth4-eye-on" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                                <svg class="auth4-eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                    <line x1="1" y1="1" x2="23" y2="23"/>
                                </svg>
                            </button>
                        </div>
                        <div class="auth4-caps" hidden role="status" aria-live="polite">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 19h.01"/><path d="M5 12l7-7 7 7"/><path d="M12 5v9"/>
                            </svg>
                            <span>Caps Lock está ativado</span>
                        </div>
                    </div>

                    <button class="auth4-submit" type="submit">Entrar</button>
                </form>
            }
            else
            {
                <div class="auth4-error">
                    <b>Erro carregando o formulário.</b>
                    <span>Recarregue a página (F5).</span>
                </div>
            }

            <div class="auth4-help">
                Não tem acesso?
                <a href="https://wa.me/5511942653054?text=Quero%20acesso%20ao%20portal" target="_blank" rel="noopener">Fala comigo no WhatsApp</a>
            </div>
        </div>

    </div>

    <div class="auth4-foot">
        <span>Sistema operacional · © @DateTime.Now.Year Gustavo Almeida</span>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    private string? _tokenField;
    private string? _tokenValue;
    private bool HasError => !string.IsNullOrEmpty(Error);
    private bool IsDemo => string.Equals(Config["App:IsDemo"], "true", StringComparison.OrdinalIgnoreCase);
    private PersistingComponentStateSubscription _subscription;

    protected override void OnInitialized()
    {
        if (State.TryTakeFromJson<string[]>("login.token", out var saved) && saved is { Length: 2 })
        {
            _tokenField = saved[0];
            _tokenValue = saved[1];
        }
        else
        {
            var ctx = HttpAccessor.HttpContext;
            if (ctx is not null)
            {
                var t = Antiforgery.GetAndStoreTokens(ctx);
                _tokenField = t.FormFieldName;
                _tokenValue = t.RequestToken;
            }
        }

        _subscription = State.RegisterOnPersisting(() =>
        {
            if (_tokenField is not null && _tokenValue is not null)
                State.PersistAsJson("login.token", new[] { _tokenField, _tokenValue });
            return Task.CompletedTask;
        });
    }

    public void Dispose() => _subscription.Dispose();
}
