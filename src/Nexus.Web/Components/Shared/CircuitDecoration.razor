@*
    Decoração de linhas de circuito (assinatura visual do cartão).
    Posicionar absolute em containers relative.
    Variants:
       "right"  — linhas vindo da direita pro centro (default)
       "left"   — espelhado
       "top"    — linhas curvas no topo
*@

<svg class="circuit-decor circuit-@Variant" viewBox="0 0 400 300"
     preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    @if (Variant == "right" || Variant == "left")
    {
        <g stroke="@Color" stroke-width="1.2" fill="none" opacity="@Opacity">
            <path d="M 400 40 L 320 40 L 300 60 L 300 110 L 280 130" />
            <path d="M 400 100 L 360 100 L 340 120 L 340 180" />
            <path d="M 400 180 L 340 180 L 320 200 L 290 200" />
            <path d="M 400 240 L 360 240 L 340 220 L 280 220" />
        </g>
        <g fill="@Color">
            <circle cx="280" cy="130" r="2.5" />
            <circle cx="340" cy="180" r="2.5" />
            <circle cx="290" cy="200" r="2.5" />
            <circle cx="280" cy="220" r="2.5" />
        </g>
    }
    else if (Variant == "top")
    {
        <g stroke="@Color" stroke-width="1.2" fill="none" opacity="@Opacity">
            <path d="M 40 0 L 40 80 L 80 120" />
            <path d="M 120 0 L 120 60 L 100 80" />
            <path d="M 260 0 L 260 100 L 220 140" />
            <path d="M 340 0 L 340 60 L 360 80" />
        </g>
        <g fill="@Color">
            <circle cx="80" cy="120" r="2.5" />
            <circle cx="100" cy="80" r="2.5" />
            <circle cx="220" cy="140" r="2.5" />
            <circle cx="360" cy="80" r="2.5" />
        </g>
    }
</svg>

@code {
    [Parameter] public string Variant { get; set; } = "right";
    [Parameter] public string Color { get; set; } = "#00c2ff";
    [Parameter] public double Opacity { get; set; } = 0.5;
}
